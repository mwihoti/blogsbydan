{
  "name": "gemflow",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered content workflow with blockchain payments for Kenyan businesses",
  "type": "module",
  "scripts": {
    "start": "node scripts/serve.js",
    "workflow": "node scripts/run-workflow.js",
    "medium": "node scripts/publish-medium.js",
    "lint": "node scripts/lint.js",
    "check": "node scripts/run-workflow.js --check",
    "test": "node --test tests/**/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:int": "node --test tests/integration/*.test.js",
    "test:watch": "node --test --watch tests/**/*.test.js",
    "test:coverage": "node --experimental-test-coverage --test tests/**/*.test.js"
  },
  "keywords": [
    "blog",
    "markdown",
    "obsidian",
    "medium",
    "writing"
  ],
  "license": "MIT"
}
